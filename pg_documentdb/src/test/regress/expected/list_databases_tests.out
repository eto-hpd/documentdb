SET search_path TO documentdb_core, documentdb_api, public;
SET documentdb.next_collection_id TO 9300;
SET documentdb.next_collection_index_id TO 9300;
-- Build three databases with different data volumes.
SELECT documentdb_api.create_collection('test_1', 'coll');
NOTICE:  creating collection
 create_collection 
-------------------
 t
(1 row)

SELECT documentdb_api.create_collection('test_2', 'coll');
NOTICE:  creating collection
 create_collection 
-------------------
 t
(1 row)

SELECT COUNT(documentdb_api.insert_one(
    'test_2',
    'coll',
    FORMAT('{ "_id": %s, "a": %s, "b": %s }', i, i, i * 2)::bson))
FROM generate_series(1, 100) AS i;
 count 
-------
   100
(1 row)

SELECT documentdb_api.create_collection('test_3', 'coll');
NOTICE:  creating collection
 create_collection 
-------------------
 t
(1 row)

SELECT COUNT(documentdb_api.insert_one(
    'test_3',
    'coll',
    FORMAT('{ "_id": %s, "a": %s, "b": %s, "c": %s }', i, i, i * 2, i * 3)::bson))
FROM generate_series(1, 1000) AS i;
 count 
-------
  1000
(1 row)

-- Test nameOnly.
SELECT documentdb_api_catalog.bson_dollar_unwind(list_databases, '$databases')
FROM documentdb_api.list_databases(
         '{
            "listDatabases": 1,
            "nameOnly": true,
            "filter": {
              "$or": [
                { "name": "test_1" },
                { "name": "test_2" },
                { "name": "test_3" }
              ]
            }
          }')
ORDER BY 1;
                             bson_dollar_unwind                              
-----------------------------------------------------------------------------
 { "databases" : { "name" : "test_1" }, "ok" : { "$numberDouble" : "1.0" } }
 { "databases" : { "name" : "test_2" }, "ok" : { "$numberDouble" : "1.0" } }
 { "databases" : { "name" : "test_3" }, "ok" : { "$numberDouble" : "1.0" } }
(3 rows)

-- Test authorizedDatabases.
SELECT documentdb_api_catalog.bson_dollar_project(
           documentdb_api_catalog.bson_dollar_unwind(list_databases, '$databases'),
           '{ "databases.name": 1, "databases.sizeOnDisk": 1, "databases.empty": 1 }')
FROM documentdb_api.list_databases(
         '{
            "listDatabases": 1,
            "authorizedDatabases": true,
            "filter": {
              "$or": [
                { "name": "test_1" },
                { "name": "test_2" },
                { "name": "test_3" }
              ]
            }
          }')
ORDER BY 1;
                                          bson_dollar_project                                          
-------------------------------------------------------------------------------------------------------
 { "databases" : { "name" : "test_1", "sizeOnDisk" : { "$numberLong" : "16384" }, "empty" : false } }
 { "databases" : { "name" : "test_2", "sizeOnDisk" : { "$numberLong" : "65536" }, "empty" : false } }
 { "databases" : { "name" : "test_3", "sizeOnDisk" : { "$numberLong" : "180224" }, "empty" : false } }
(3 rows)

SELECT documentdb_api_catalog.bson_dollar_project(
           list_databases,
           '{ "totalSize": 1, "ok": 1 }')
FROM documentdb_api.list_databases(
         '{
            "listDatabases": 1,
            "authorizedDatabases": true,
            "filter": {
              "$or": [
                { "name": "test_1" },
                { "name": "test_2" },
                { "name": "test_3" }
              ]
            }
          }');
                                bson_dollar_project                                 
------------------------------------------------------------------------------------
 { "totalSize" : { "$numberLong" : "262144" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

